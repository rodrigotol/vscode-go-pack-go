{
  "name": "go-pack-go",
  "displayName": "Go Pack Go",
  "description": "VS Code Go productivity features for table tests, type implementations, main entrypoints and enhanced find references",
  "version": "0.0.1",
  "publisher": "rodrigotol",
  "main": "./out/extension.js",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "go",
    "golang",
    "codelens",
    "debug",
    "testing"
  ],
  "activationEvents": [
    "onLanguage:go"
  ],
  "extensionDependencies": [
    "golang.go"
  ],
  "contributes": {
    "commands": [
      {
        "command": "go-pack-go.runGoMain",
        "title": "Go Pack Go: Run Go Main"
      },
      {
        "command": "go-pack-go.debugGoMain",
        "title": "Go Pack Go: Debug Go Main"
      },
      {
        "command": "go-pack-go.findReferences",
        "title": "Go to References (Go Pack Go)"
      },
      {
        "command": "go-pack-go.openReference",
        "title": "Open Reference"
      },
      {
        "command": "go-pack-go.toggleWrite",
        "title": "Toggle Write Usages",
        "icon": "$(pencil)"
      },
      {
        "command": "go-pack-go.toggleRead",
        "title": "Toggle Read Usages",
        "icon": "$(eye)"
      },
      {
        "command": "go-pack-go.toggleOther",
        "title": "Toggle Other Usages",
        "icon": "$(symbol-misc)"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "go-pack-go",
          "title": "Go Pack Go - References",
          "icon": "$(references)"
        }
      ]
    },
    "views": {
      "go-pack-go": [
        {
          "id": "go-pack-go.referencesView",
          "name": "References",
          "type": "tree"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "go-pack-go.findReferences",
          "when": "editorTextFocus",
          "group": "navigation@99"
        }
      ],
      "view/title": [
        {
          "command": "go-pack-go.toggleWrite",
          "when": "view == go-pack-go.referencesView",
          "group": "navigation@1"
        },
        {
          "command": "go-pack-go.toggleRead",
          "when": "view == go-pack-go.referencesView",
          "group": "navigation@2"
        },
        {
          "command": "go-pack-go.toggleOther",
          "when": "view == go-pack-go.referencesView",
          "group": "navigation@3"
        }
      ]
    },
    "configuration": {
      "title": "Go Pack Go",
      "properties": {
        "goPackGo.enableDebugLogs": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose logging for the Go main runner feature."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node esbuild.js",
    "typecheck": "tsc --noEmit",
    "watch": "node esbuild.js --watch",
    "package": "vsce package",
    "test": "npm run compile && node --test \"out/**/*.test.js\""
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/vscode": "^1.120.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.5.2"
  },
  "dependencies": {
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.20.8"
  }
}